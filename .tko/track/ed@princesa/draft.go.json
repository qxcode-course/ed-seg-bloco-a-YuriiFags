            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n    var qtd, E int\n    fmt.Scan(&qtd, &E)\n\n    vivos := make([]bool, qtd)\n\n    for i := 0; i < qtd; i++ {\n        vivos[i] = true\n    }\n\n    vivosCount := qtd\n    pos := E - 1\n\n    // estado inicial\n    fmt.Print(\"[ \")\n    for i := 0; i < qtd; i++ {\n        if i == pos {\n            fmt.Printf(\"%d> \", i+1)\n        } else {\n            fmt.Printf(\"%d \", i+1)\n        }\n    }\n    fmt.Println(\"]\")\n\n    for vivosCount > 1 {\n        prox := (pos + 1) % qtd\n\n        for vivos[prox] == false {\n            prox = (prox + 1) % qtd\n        }\n\n        vivos[prox] = false\n        vivosCount--\n\n        pos = (prox + 1) % qtd\n        for vivos[pos] == false {\n            pos = (pos + 1) % qtd\n        }\n\n        fmt.Print(\"[ \")\n        for i := 0; i < qtd; i++ {\n            if vivos[i] {\n                if i == pos {\n                    fmt.Printf(\"%d> \", i+1)\n                } else {\n                    fmt.Printf(\"%d \", i+1)\n                }\n            }\n        }\n        fmt.Println(\"]\")\n    }\n}",
